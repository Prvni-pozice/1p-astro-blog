---
// CrowdVideo — scroll-scrubbed video nad footerem (bez parallaxu)
// JS: motion.js → initCrowdScrub()
---

<section class="crowd-section" aria-hidden="true">
  <video
    class="crowd-video"
    muted
    playsinline
    disableremoteplayback
    preload="none"
    width="1920"
    height="1080"
    poster="/assets/footer/crowd-poster.webp"
  >
    <!-- all-keyframe H.264 1080p 15fps — 3 MB, okamžitý seek bez lag -->
    <source src="/assets/footer/crowd-scrub.mp4" type="video/mp4" />
  </video>
  <div class="crowd-glow-overlay" aria-hidden="true"></div>
</section>

<style>
  .crowd-section {
    position: relative;
    width: 100%;
    /* 16:9 výška, max 80vh */
    aspect-ratio: 16 / 9;
    max-height: 80vh;
    overflow: hidden;
    margin-bottom: -2px; /* napojení na footer bez mezery */
  }

  .crowd-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .crowd-glow-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
    background: radial-gradient(ellipse at 50% 40%, rgba(174, 211, 1, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .crowd-section.scrub-complete .crowd-glow-overlay {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .crowd-section {
      max-height: 60vw; /* trochu vyšší na mobilu */
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .crowd-glow-overlay { opacity: 1 !important; transition: none !important; }
  }
</style>
