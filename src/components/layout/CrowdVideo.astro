---
// CrowdVideo — scroll-scrubbed parallax video nad footerem
// Video: /public/assets/footer/crowd-video.mp4 (1920×1080, H.264)
// Poster (volitelný): /public/assets/footer/crowd-poster.webp
// JS scroll-scrub: motion.js → initCrowdScrub()
---

<section class="crowd-parallax" aria-hidden="true">
  <div class="crowd-sticky">
    <video
      class="crowd-video"
      muted
      playsinline
      disableremoteplayback
      preload="none"
      width="1920"
      height="1080"
      poster="/assets/footer/crowd-poster.webp"
    >
      <!-- WebM VP9 preferován — menší soubor (4.1 MB vs 6.7 MB) -->
      <source src="/assets/footer/crowd-video.webm" type="video/webm" />
      <source src="/assets/footer/crowd-video.mp4" type="video/mp4" />
    </video>
    <div class="crowd-glow-overlay" aria-hidden="true"></div>
  </div>
</section>

<style>
  /* Wrapper: vytváří scroll prostor pro scrub + parallax */
  .crowd-parallax {
    position: relative;
    height: calc(56.25vw + 40vh);
    overflow: hidden;
  }

  /* Sticky bottom = parallax efekt: video "sedí" dole, obsah přes něj přejíždí */
  .crowd-sticky {
    position: sticky;
    bottom: 0;
    width: 100%;
    height: 56.25vw; /* 16:9 aspect ratio */
    max-height: 80vh;
    overflow: hidden;
  }

  .crowd-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Glow overlay — aktivuje se když jsou lidé otočení (CSS class z JS) */
  .crowd-glow-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
    background: radial-gradient(
      ellipse at 50% 40%,
      rgba(174, 211, 1, 0.1) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .crowd-parallax.scrub-complete .crowd-glow-overlay {
    opacity: 1;
  }

  /* Tablet: menší scroll range */
  @media (max-width: 1023px) {
    .crowd-parallax {
      height: calc(56.25vw + 30vh);
    }
  }

  /* Mobil: zachovej min výšku */
  @media (max-width: 767px) {
    .crowd-sticky {
      min-height: 40vh;
    }
  }

  /* Reduced motion: statický poslední frame (JS nastaví currentTime = duration) */
  @media (prefers-reduced-motion: reduce) {
    .crowd-glow-overlay {
      opacity: 1 !important;
      transition: none !important;
    }
  }
</style>
