---
import FooterCrowd from './FooterCrowd.astro';

const year = new Date().getFullYear();

const navItems = [
  { label: 'Úvod', href: '/' },
  { label: 'AI', href: '/ai/' },
  { label: 'GEO', href: '/geo/' },
];
---

<FooterCrowd />
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="První pozice Blog">
          <span class="logo-mark" aria-hidden="true">1P</span>
          <span class="footer-logo-text">
            <span>První pozice</span>
            <span class="footer-logo-sub">Blog</span>
          </span>
        </a>
        <p class="footer-tagline">
          Znalosti pro AI-first svět.<br />
          SEO, GEO a budoucnost vyhledávání.
        </p>
        <a
          href="https://www.youtube.com/@prvnipozice"
          class="footer-yt"
          target="_blank"
          rel="noopener"
          aria-label="YouTube kanál První pozice"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          YouTube kanál
        </a>
      </div>

      <!-- Nav -->
      <div class="footer-nav">
        <h4 class="footer-nav-title">Sekce</h4>
        <ul role="list">
          {navItems.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div class="footer-nav">
        <h4 class="footer-nav-title">Zdroje</h4>
        <ul role="list">
          <li><a href="/rss.xml">RSS Feed</a></li>
          <li>
            <a href="https://www.prvni-pozice.com" target="_blank" rel="noopener">
              Hlavní web
            </a>
          </li>
          <li>
            <a href="https://www.youtube.com/@prvnipozice" target="_blank" rel="noopener">
              YouTube
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        © {year} <a href="https://www.prvni-pozice.com" target="_blank" rel="noopener">První pozice</a>.
        Všechna práva vyhrazena.
      </p>
      <p class="footer-made">
        Blog postaven na <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
      </p>
    </div>
  </div>

  <!-- Ambient decoration -->
  <div class="footer-glow" aria-hidden="true"></div>
</footer>

<style>
  .site-footer {
    position: relative;
    border-top: 1px solid var(--border);
    padding-top: 4rem;
    padding-bottom: 2rem;
    overflow: hidden;
  }

  .footer-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 200px;
    background: radial-gradient(ellipse at center, rgba(174, 211, 1, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  /* ── Brand ── */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--accent);
    color: #08080d;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .footer-logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
    color: var(--text-heading);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .footer-logo-sub {
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .footer-yt {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ff4444;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity var(--duration) var(--ease);
  }

  .footer-yt:hover {
    opacity: 0.8;
    color: #ff4444;
  }

  /* ── Nav ── */
  .footer-nav-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-nav a {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer-nav a:hover {
    color: var(--accent);
  }

  /* ── Bottom ── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .footer-copy a,
  .footer-made a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer-copy a:hover,
  .footer-made a:hover {
    color: var(--accent);
  }
</style>
