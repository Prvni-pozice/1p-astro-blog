<!--
  FooterCrowd — crossfade crowd sekce
  Dva obrázky: crowd-away (lidé se dívají různými směry) + crowd-looking (všichni se dívají na vás).
  Trigger: IntersectionObserver (z motion.js) přidá .is-active → crossfade + scale zoom.
-->
<div class="crowd-section" data-crowd-trigger>

  <!-- crowd-away.webp: lidé se dívají různými směry (výchozí stav)
       REPLACE: src/assets/footer/crowd-away.webp
       Rozměry: 1920×600 px, bez průhlednosti, max 150 KB
       Viz: docs/image-specs.md -->
  <div class="crowd-img crowd-away" role="presentation">
    <div class="ph-crowd ph-crowd-away" aria-hidden="true">
      <span class="ph-crowd-label">crowd-away.webp placeholder<br/><small>Lidé se dívají různými směry</small></span>
      <div class="ph-silhouettes ph-silhouettes-away" aria-hidden="true"></div>
    </div>
  </div>

  <!-- crowd-looking.webp: STEJNÍ lidé, všichni se dívají do kamery (finální stav)
       REPLACE: src/assets/footer/crowd-looking.webp
       Rozměry: 1920×600 px, bez průhlednosti, max 150 KB
       Viz: docs/image-specs.md -->
  <div class="crowd-img crowd-looking" role="img" aria-label="Publikum v AR brýlích se dívá na vás">
    <div class="ph-crowd ph-crowd-looking" aria-hidden="true">
      <span class="ph-crowd-label">crowd-looking.webp placeholder<br/><small>Všichni se dívají přímo na vás</small></span>
      <div class="ph-silhouettes ph-silhouettes-looking" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Glow overlay: záře z AR brýlí po přechodu -->
  <div class="crowd-glow-overlay" aria-hidden="true"></div>
</div>

<style>
  .crowd-section {
    position: relative;
    width: 100%;
    height: clamp(200px, 30vw, 600px);
    overflow: hidden;
    margin-bottom: -2px;
  }

  /* Oba obrázky absolutně, přes celou sekci */
  .crowd-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* crowd-away je vždy viditelný */
  .crowd-away {
    z-index: 1;
  }

  /* crowd-looking je průhledný → crossfade na trigger */
  .crowd-looking {
    z-index: 2;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  /* Trigger: .is-active přidán z motion.js */
  .crowd-section.is-active .crowd-looking {
    opacity: 1;
  }

  /* Jemný zoom při přechodu */
  .crowd-section.is-active {
    transform: scale(1.02);
    transition: transform 1.5s ease-out;
  }

  /* Glow overlay — záře z brýlí */
  .crowd-glow-overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: radial-gradient(ellipse 60% 40% at 50% 80%, rgba(1,211,174,0.05) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease 1s;
  }
  .crowd-section.is-active .crowd-glow-overlay {
    opacity: 1;
    animation: crowdGlowPulse 4s ease-in-out infinite 1.5s;
  }
  @keyframes crowdGlowPulse {
    0%,100% { opacity: 0.6; }
    50%      { opacity: 1; }
  }

  /* ── Placeholder vizuály (dočasné) ── */
  .ph-crowd {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .ph-crowd-away {
    background: linear-gradient(180deg,
      #08080d 0%,
      #0c0d1a 20%,
      #0e0f1c 50%,
      #0a0b16 80%,
      #08080d 100%
    );
  }

  .ph-crowd-looking {
    background: linear-gradient(180deg,
      #06060c 0%,
      #0a0c18 20%,
      #0d1020 50%,
      #090c16 80%,
      #06060c 100%
    );
  }

  .ph-crowd-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.15);
    text-align: center;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    position: relative;
    z-index: 2;
  }
  .ph-crowd-label small {
    display: block;
    font-size: 0.65rem;
    margin-top: 0.2rem;
    opacity: 0.7;
  }

  /* Silhouettes — jednoduché CSS siluety naznačující skupinu lidí */
  .ph-silhouettes {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 85%;
    background:
      /* Řada siluet — hlavy -->
      radial-gradient(ellipse 3% 8% at 8% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 16% 14%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 9% at 24% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 32% 15%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 4% 10% at 41% 12%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 9% at 50% 16%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 4% 10% at 59% 12%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 68% 15%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 9% at 76% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 84% 14%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 92% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      /* Těla — gradient základ */
      linear-gradient(180deg, transparent 0%, rgba(10,11,20,0.5) 30%, rgba(8,9,16,0.9) 100%);
  }

  .ph-silhouettes-looking {
    /* Brýle — teal glow efekt u každé siluety */
    background:
      radial-gradient(ellipse 1.5% 3% at 8% 19%, rgba(1,211,174,0.4) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 16% 15%, rgba(174,211,1,0.35) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 24% 19%, rgba(1,211,174,0.4) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 32% 16%, rgba(174,211,1,0.35) 0%, transparent 100%),
      radial-gradient(ellipse 2% 4% at 41% 13%, rgba(1,211,174,0.5) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 50% 17%, rgba(174,211,1,0.4) 0%, transparent 100%),
      radial-gradient(ellipse 2% 4% at 59% 13%, rgba(1,211,174,0.5) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 68% 16%, rgba(174,211,1,0.35) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 76% 19%, rgba(1,211,174,0.4) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 84% 15%, rgba(174,211,1,0.35) 0%, transparent 100%),
      radial-gradient(ellipse 1.5% 3% at 92% 19%, rgba(1,211,174,0.4) 0%, transparent 100%),
      /* Hlavy */
      radial-gradient(ellipse 3% 8% at 8% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 16% 14%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 9% at 24% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 32% 15%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 4% 10% at 41% 12%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 9% at 50% 16%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 4% 10% at 59% 12%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 68% 15%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 9% at 76% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 84% 14%, rgba(20,22,35,0.9) 0%, transparent 100%),
      radial-gradient(ellipse 3% 8% at 92% 18%, rgba(20,22,35,0.9) 0%, transparent 100%),
      linear-gradient(180deg, transparent 0%, rgba(8,9,16,0.5) 30%, rgba(6,7,14,0.9) 100%);
  }

  /* ── Reduced motion: rovnou finální stav ── */
  @media (prefers-reduced-motion: reduce) {
    .crowd-looking { opacity: 1 !important; transition: none !important; }
    .crowd-section { transform: none !important; transition: none !important; }
    .crowd-glow-overlay { opacity: 1 !important; animation: none !important; }
  }
</style>
