---
import { Image } from 'astro:assets';
import crowdAway from '../../assets/footer/crowd.png';
import crowdLooking from '../../assets/footer/crowd2.png';
---

<!--
  FooterCrowd — crossfade crowd sekce
  crowd.png  = crowd-away  (lidé hledí do VR headsetů různými směry)
  crowd2.png = crowd-looking (dav kouká přímo na tebe)
  Trigger: motion.js přidá .is-active na [data-crowd-trigger] → crossfade
-->
<div class="crowd-section" data-crowd-trigger>

  <!-- Výchozí stav: lidé se dívají do headsetů -->
  <Image
    src={crowdAway}
    alt=""
    class="crowd-img crowd-away"
    width={1920}
    height={600}
    format="webp"
    quality={80}
    loading="lazy"
    decoding="async"
  />

  <!-- Finální stav: všichni kouká na tebe (crossfade při scroll) -->
  <Image
    src={crowdLooking}
    alt="Dav v VR headsetech se dívá přímo na vás"
    class="crowd-img crowd-looking"
    width={1920}
    height={600}
    format="webp"
    quality={80}
    loading="lazy"
    decoding="async"
  />

  <!-- Glow overlay: záře z headsetů po přechodu -->
  <div class="crowd-glow-overlay" aria-hidden="true"></div>
</div>

<style>
  .crowd-section {
    position: relative;
    width: 100%;
    height: clamp(200px, 28vw, 560px);
    overflow: hidden;
    margin-bottom: -2px;
  }

  .crowd-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .crowd-away  { z-index: 1; }

  .crowd-looking {
    z-index: 2;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  /* Trigger z motion.js */
  .crowd-section.is-active .crowd-looking {
    opacity: 1;
  }

  .crowd-section.is-active {
    transform: scale(1.02);
    transition: transform 1.5s ease-out;
  }

  /* Glow overlay — záře headsetů */
  .crowd-glow-overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: radial-gradient(ellipse 60% 50% at 50% 80%, rgba(1,211,174,0.06) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease 1s;
  }

  .crowd-section.is-active .crowd-glow-overlay {
    opacity: 1;
    animation: crowdGlowPulse 4s ease-in-out infinite 1.5s;
  }

  @keyframes crowdGlowPulse {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .crowd-looking  { opacity: 1 !important; transition: none !important; }
    .crowd-section  { transform: none !important; transition: none !important; }
    .crowd-glow-overlay { opacity: 1 !important; animation: none !important; }
  }
</style>
