---
import CategoryBadge from '../ui/CategoryBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, category, readingTime } = post.data;

const formattedDate = pubDate.toLocaleDateString('cs-CZ', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const slug = post.slug;
---

<article class={`blog-card ${featured ? 'featured' : ''}`}>
  <a href={`/blog/${slug}/`} class="card-link" tabindex="-1" aria-hidden="true"></a>

  <div class="card-top">
    <CategoryBadge category={category} size="sm" />
    {readingTime && (
      <span class="card-reading">{readingTime} min</span>
    )}
  </div>

  <h2 class="card-title">
    <a href={`/blog/${slug}/`}>{title}</a>
  </h2>

  <p class="card-description">{description}</p>

  <div class="card-footer">
    <time datetime={pubDate.toISOString()} class="card-date">{formattedDate}</time>
    <span class="card-arrow" aria-hidden="true">→</span>
  </div>

  <!-- Ambient glow on hover -->
  <div class="card-glow" aria-hidden="true"></div>
</article>

<style>
  .blog-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: hidden;
    transition:
      border-color var(--duration) var(--ease),
      transform var(--duration) var(--ease),
      box-shadow var(--duration) var(--ease);
  }

  .blog-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .blog-card:hover .card-glow {
    opacity: 1;
  }

  .blog-card:hover .card-arrow {
    transform: translateX(4px);
  }

  /* Featured variant */
  .blog-card.featured {
    border-color: var(--border-accent);
  }

  /* Glow */
  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% -20%, var(--accent-dim) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }

  /* Full-card link (invisible overlay) */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Top row */
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }

  .card-reading {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* Title */
  .card-title {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.3;
    position: relative;
    z-index: 1;
  }

  .card-title a {
    color: var(--text-heading);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .card-title a:hover {
    color: var(--accent);
  }

  /* Description */
  .card-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    position: relative;
    z-index: 1;
    flex: 1;
  }

  /* Footer */
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    position: relative;
    z-index: 1;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .card-arrow {
    color: var(--accent);
    font-size: 1rem;
    transition: transform var(--duration) var(--ease);
  }
</style>
