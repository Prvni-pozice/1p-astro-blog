---
import BlogCard from '../blog/BlogCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<section class="featured-posts section" aria-labelledby="posts-heading">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-tag">Nejnovější</div>
      <h2 id="posts-heading" class="section-title">Články a průvodce</h2>
      <p class="section-lead">
        Praktické znalosti o SEO, GEO a AI vyhledávání pro vaši firmu.
      </p>
    </div>

    <div class="posts-grid">
      {posts.map((post, i) => (
        <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
          <BlogCard post={post} featured={post.data.featured} />
        </div>
      ))}
    </div>

    <div class="posts-more reveal">
      <a href="/ai/" class="more-link">Všechny AI články →</a>
      <span class="more-divider" aria-hidden="true">·</span>
      <a href="/geo/" class="more-link">Všechny GEO články →</a>
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .section-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-title {
    margin-bottom: 0.75rem;
  }

  .section-lead {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: 1.25rem;
  }

  .posts-more {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.5rem;
    justify-content: center;
  }

  .more-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .more-link:hover {
    color: var(--accent);
  }

  .more-divider {
    color: var(--border);
  }
</style>
