---
// Static YouTube section — no iframe, no API calls, no performance impact
// Click opens YouTube channel in new tab

const videos = [
  {
    id: 'placeholder-1',
    title: 'Co je GEO a jak funguje v roce 2026',
    views: '2.4K',
    date: 'Březen 2026',
  },
  {
    id: 'placeholder-2',
    title: 'AI nástroje pro SEO: přehled nástrojů',
    views: '1.8K',
    date: 'Únor 2026',
  },
  {
    id: 'placeholder-3',
    title: 'Schema markup krok za krokem',
    views: '3.1K',
    date: 'Leden 2026',
  },
];

const channelUrl = 'https://www.youtube.com/@prvnipozice';
---

<section class="yt-section section" aria-labelledby="yt-heading">
  <div class="container">
    <div class="yt-inner reveal">
      <!-- Section label -->
      <div class="yt-header">
        <div class="yt-label">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="yt-icon" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          YouTube kanál
        </div>
        <h2 id="yt-heading" class="yt-title">
          Sledujte První pozice na YouTube
        </h2>
        <p class="yt-description">
          Videa o SEO, GEO, AI nástrojích a digitálním marketingu.<br />
          Prakticky, bez zbytečné teorie.
        </p>
      </div>

      <!-- Video previews (static, click to YouTube) -->
      <div class="yt-videos">
        {videos.map((video, i) => (
          <a
            href={channelUrl}
            target="_blank"
            rel="noopener"
            class="yt-card"
            aria-label={`${video.title} — přejít na YouTube kanál`}
            style={`animation-delay: ${i * 0.1}s`}
          >
            <!-- Thumbnail placeholder -->
            <div class="yt-thumb" aria-hidden="true">
              <div class="yt-thumb-bg"></div>
              <div class="yt-play">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
              <div class="yt-network-mini" aria-hidden="true">
                <svg viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg">
                  <g stroke="rgba(174,211,1,0.25)" stroke-width="1" fill="none">
                    <line x1="40" y1="30" x2="15" y2="15"/>
                    <line x1="40" y1="30" x2="65" y2="15"/>
                    <line x1="40" y1="30" x2="15" y2="45"/>
                    <line x1="40" y1="30" x2="65" y2="45"/>
                  </g>
                  <circle cx="40" cy="30" r="5" fill="rgba(174,211,1,0.6)"/>
                  <circle cx="15" cy="15" r="3" fill="rgba(174,211,1,0.3)"/>
                  <circle cx="65" cy="15" r="3" fill="rgba(174,211,1,0.3)"/>
                  <circle cx="15" cy="45" r="3" fill="rgba(174,211,1,0.3)"/>
                  <circle cx="65" cy="45" r="3" fill="rgba(174,211,1,0.3)"/>
                </svg>
              </div>
            </div>
            <div class="yt-card-body">
              <p class="yt-card-title">{video.title}</p>
              <div class="yt-card-meta">
                <span>{video.views} zhlédnutí</span>
                <span>·</span>
                <span>{video.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="yt-cta">
        <a
          href={channelUrl}
          target="_blank"
          rel="noopener"
          class="yt-btn"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Odebírat kanál @prvnipozice
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .yt-section {
    padding-bottom: calc(var(--section-gap) * 1.5);
  }

  .yt-inner {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius-lg) * 1.5);
    padding: clamp(2rem, 5vw, 3.5rem);
    position: relative;
    overflow: hidden;
  }

  /* Ambient glow */
  .yt-inner::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 100%;
    background: radial-gradient(ellipse, rgba(255, 68, 68, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .yt-header {
    max-width: 600px;
    margin-bottom: 2rem;
    position: relative;
  }

  .yt-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: #ff4444;
    margin-bottom: 0.75rem;
    letter-spacing: 0.04em;
  }

  .yt-icon {
    flex-shrink: 0;
  }

  .yt-title {
    margin-bottom: 0.75rem;
    font-size: clamp(1.4rem, 3vw, 2rem);
  }

  .yt-description {
    color: var(--text-muted);
    font-size: 0.9375rem;
    max-width: none;
  }

  /* ── Video cards ── */
  .yt-videos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .yt-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-2);
    border: 1px solid var(--border);
    transition:
      border-color var(--duration) var(--ease),
      transform var(--duration) var(--ease);
  }

  .yt-card:hover {
    border-color: rgba(255, 68, 68, 0.3);
    transform: translateY(-2px);
  }

  .yt-card:hover .yt-play {
    background: #ff4444;
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* Thumbnail */
  .yt-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-base);
    overflow: hidden;
  }

  .yt-thumb-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 30%, rgba(174, 211, 1, 0.06) 0%, transparent 70%);
  }

  .yt-network-mini {
    position: absolute;
    inset: 0;
    padding: 0.5rem;
  }

  .yt-network-mini svg {
    width: 100%;
    height: 100%;
  }

  .yt-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    background: rgba(255, 68, 68, 0.8);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition:
      background var(--duration) var(--ease),
      transform var(--duration) var(--ease);
    backdrop-filter: blur(4px);
  }

  /* Card body */
  .yt-card-body {
    padding: 0.75rem;
    flex: 1;
  }

  .yt-card-title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.4;
    margin-bottom: 0.4rem;
    max-width: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .yt-card-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ── CTA ── */
  .yt-cta {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .yt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #ff4444;
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.75rem 1.75rem;
    border-radius: 100px;
    text-decoration: none;
    transition:
      background var(--duration) var(--ease),
      transform var(--duration) var(--ease),
      box-shadow var(--duration) var(--ease);
  }

  .yt-btn:hover {
    background: #e03333;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 68, 68, 0.3);
  }
</style>
