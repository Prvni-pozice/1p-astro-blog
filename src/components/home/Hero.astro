---
---

<section class="hero" aria-label="Úvod">
  <!-- Animated nebula background -->
  <div class="hero-nebula" aria-hidden="true">
    <div class="nebula-layer nebula-1"></div>
    <div class="nebula-layer nebula-2"></div>
    <div class="nebula-layer nebula-3"></div>
  </div>

  <!-- Neural network SVG (AI entity) -->
  <div class="hero-network" id="heroNetwork" aria-hidden="true">
    <svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" class="network-svg">
      <!-- Connection lines -->
      <g class="network-lines" stroke="rgba(174,211,1,0.15)" stroke-width="1" fill="none">
        <line x1="200" y1="160" x2="90"  y2="80"  class="nl" style="--d:0.0s"/>
        <line x1="200" y1="160" x2="310" y2="80"  class="nl" style="--d:0.1s"/>
        <line x1="200" y1="160" x2="90"  y2="240" class="nl" style="--d:0.2s"/>
        <line x1="200" y1="160" x2="310" y2="240" class="nl" style="--d:0.3s"/>
        <line x1="200" y1="160" x2="50"  y2="160" class="nl" style="--d:0.4s"/>
        <line x1="200" y1="160" x2="350" y2="160" class="nl" style="--d:0.5s"/>
        <line x1="90"  y1="80"  x2="310" y2="80"  class="nl" style="--d:0.6s"/>
        <line x1="90"  y1="240" x2="310" y2="240" class="nl" style="--d:0.7s"/>
        <line x1="90"  y1="80"  x2="50"  y2="160" class="nl" style="--d:0.8s"/>
        <line x1="310" y1="80"  x2="350" y2="160" class="nl" style="--d:0.9s"/>
        <line x1="90"  y1="240" x2="50"  y2="160" class="nl" style="--d:1.0s"/>
        <line x1="310" y1="240" x2="350" y2="160" class="nl" style="--d:1.1s"/>
        <!-- Outer ring connections -->
        <line x1="90"  y1="80"  x2="30"  y2="30"  class="nl" style="--d:0.2s"/>
        <line x1="310" y1="80"  x2="370" y2="30"  class="nl" style="--d:0.3s"/>
        <line x1="90"  y1="240" x2="30"  y2="290" class="nl" style="--d:0.4s"/>
        <line x1="310" y1="240" x2="370" y2="290" class="nl" style="--d:0.5s"/>
      </g>

      <!-- Outer nodes -->
      <g class="network-nodes-outer">
        <circle cx="30"  cy="30"  r="3" class="nn-outer" style="--d:0.0s"/>
        <circle cx="370" cy="30"  r="3" class="nn-outer" style="--d:0.2s"/>
        <circle cx="30"  cy="290" r="3" class="nn-outer" style="--d:0.4s"/>
        <circle cx="370" cy="290" r="3" class="nn-outer" style="--d:0.6s"/>
      </g>

      <!-- Mid nodes -->
      <g class="network-nodes-mid">
        <circle cx="50"  cy="160" r="5" class="nn-mid" style="--d:0.1s"/>
        <circle cx="350" cy="160" r="5" class="nn-mid" style="--d:0.3s"/>
        <circle cx="90"  cy="80"  r="6" class="nn-mid" style="--d:0.5s"/>
        <circle cx="310" cy="80"  r="6" class="nn-mid" style="--d:0.7s"/>
        <circle cx="90"  cy="240" r="6" class="nn-mid" style="--d:0.9s"/>
        <circle cx="310" cy="240" r="6" class="nn-mid" style="--d:1.1s"/>
      </g>

      <!-- Center node (main AI entity) -->
      <circle cx="200" cy="160" r="16" class="nn-center-ring" />
      <circle cx="200" cy="160" r="10" class="nn-center" />
      <circle cx="200" cy="160" r="5"  class="nn-center-core" />

      <!-- Pulse ring -->
      <circle cx="200" cy="160" r="16" class="nn-pulse" />
    </svg>
  </div>

  <!-- Dot grid overlay -->
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- Content -->
  <div class="container hero-content">
    <div class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      AI-first znalosti pro rok 2026
    </div>

    <h1 class="hero-title">
      Budoucnost vyhledávání<br />
      <span class="hero-accent">začíná teď</span>
    </h1>

    <p class="hero-lead">
      Blog o SEO, GEO a umělé inteligenci od týmu <strong>První pozice</strong>.<br />
      Praktické znalosti pro firmy, které nechtějí být překvapeny.
    </p>

    <div class="hero-actions">
      <a href="/ai/" class="btn-primary">
        Začít číst
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="/geo/" class="btn-ghost">Sekce GEO →</a>
    </div>

    <!-- Stats -->
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">2</span>
        <span class="stat-label">Sekce</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">AI</span>
        <span class="stat-label">Zaměření</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Prakticky</span>
      </div>
    </div>
  </div>
</section>

<!-- Mouse parallax script -->
<script>
  const network = document.getElementById('heroNetwork');
  if (network && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let rafId: number;
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;

    document.addEventListener('mousemove', (e) => {
      const { innerWidth, innerHeight } = window;
      targetX = ((e.clientX / innerWidth) - 0.5) * 20;
      targetY = ((e.clientY / innerHeight) - 0.5) * 10;
    }, { passive: true });

    function animate() {
      currentX += (targetX - currentX) * 0.06;
      currentY += (targetY - currentY) * 0.06;
      network!.style.transform = `translate(${currentX}px, ${currentY}px)`;
      rafId = requestAnimationFrame(animate);
    }
    animate();
  }
</script>

<style>
  /* ── Hero container ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  /* ── Nebula layers ── */
  .hero-nebula {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .nebula-layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    animation: nebulaPulse 12s ease-in-out infinite alternate;
  }

  .nebula-1 {
    width: 70%;
    height: 60%;
    top: -10%;
    left: 20%;
    background: radial-gradient(ellipse, rgba(174, 211, 1, 0.07) 0%, transparent 70%);
    animation-delay: 0s;
  }

  .nebula-2 {
    width: 50%;
    height: 50%;
    bottom: 0;
    right: -10%;
    background: radial-gradient(ellipse, rgba(1, 211, 174, 0.05) 0%, transparent 70%);
    animation-delay: -4s;
    animation-duration: 16s;
  }

  .nebula-3 {
    width: 40%;
    height: 40%;
    bottom: 10%;
    left: -5%;
    background: radial-gradient(ellipse, rgba(174, 211, 1, 0.04) 0%, transparent 70%);
    animation-delay: -8s;
    animation-duration: 20s;
  }

  @keyframes nebulaPulse {
    0%   { opacity: 0.6; transform: scale(1); }
    100% { opacity: 1;   transform: scale(1.08); }
  }

  /* ── Dot grid ── */
  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(174, 211, 1, 0.12) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Neural network ── */
  .hero-network {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(280px, 35vw, 440px);
    opacity: 0.6;
    will-change: transform;
    transition: transform 0.1s linear;
  }

  @media (max-width: 768px) {
    .hero-network {
      width: 220px;
      right: 0;
      opacity: 0.3;
    }
  }

  .network-svg {
    width: 100%;
    height: auto;
  }

  /* Network nodes animations */
  .nl {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: drawLine 1.5s var(--d, 0s) var(--ease) forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  .nn-outer {
    fill: rgba(174, 211, 1, 0.3);
    animation: nodeAppear 0.5s var(--d, 0s) ease both, nodePulse 3s var(--d, 0s) ease-in-out infinite;
  }

  .nn-mid {
    fill: rgba(174, 211, 1, 0.5);
    animation: nodeAppear 0.5s var(--d, 0s) ease both, nodePulse 4s var(--d, 0s) ease-in-out infinite;
  }

  .nn-center {
    fill: var(--accent);
    animation: nodeAppear 0.3s 0.5s ease both;
  }

  .nn-center-ring {
    fill: rgba(174, 211, 1, 0.1);
    stroke: rgba(174, 211, 1, 0.4);
    stroke-width: 1;
    animation: nodeAppear 0.3s 0.4s ease both;
  }

  .nn-center-core {
    fill: #fff;
    animation: nodeAppear 0.3s 0.6s ease both, coreGlow 2s ease-in-out infinite alternate;
  }

  .nn-pulse {
    fill: none;
    stroke: rgba(174, 211, 1, 0.6);
    stroke-width: 1;
    animation: pulse-ring 2.5s ease-out infinite;
  }

  @keyframes nodeAppear {
    from { opacity: 0; transform: scale(0); }
    to   { opacity: 1; transform: scale(1); }
  }

  @keyframes nodePulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 0.9; }
  }

  @keyframes coreGlow {
    from { fill: rgba(255,255,255,0.8); }
    to   { fill: rgba(174, 211, 1, 0.9); }
  }

  @keyframes pulse-ring {
    0%   { r: 16; opacity: 0.8; }
    100% { r: 40; opacity: 0; }
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 4rem;
    max-width: 680px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: rgba(174, 211, 1, 0.08);
    border: 1px solid rgba(174, 211, 1, 0.2);
    border-radius: 100px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.75rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: badgeBlink 2s ease-in-out infinite;
  }

  @keyframes badgeBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .hero-accent {
    color: var(--accent);
    display: inline;
  }

  .hero-lead {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 56ch;
    margin-bottom: 2rem;
  }

  .hero-lead strong {
    color: var(--text);
  }

  /* ── Actions ── */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: #08080d;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    text-decoration: none;
    transition:
      background var(--duration) var(--ease),
      transform var(--duration) var(--ease),
      box-shadow var(--duration) var(--ease);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: #08080d;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    padding: 0.7rem 0;
    transition: color var(--duration) var(--ease);
  }

  .btn-ghost:hover {
    color: var(--text);
  }

  /* ── Stats ── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }
</style>
