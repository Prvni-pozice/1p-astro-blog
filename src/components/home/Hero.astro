---
---

<section class="hero" aria-label="Úvod">
  <!-- Animated nebula background -->
  <div class="hero-nebula" aria-hidden="true">
    <div class="nebula-layer nebula-1"></div>
    <div class="nebula-layer nebula-2"></div>
    <div class="nebula-layer nebula-3"></div>
  </div>

  <!-- Dot grid overlay -->
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- MacBook + Robot scene (right side) -->
  <div class="hero-scene" id="heroScene" aria-hidden="true">
    <svg
      id="heroSceneSvg"
      viewBox="0 0 460 340"
      xmlns="http://www.w3.org/2000/svg"
      class="scene-svg"
      overflow="visible"
    >
      <defs>
        <!-- Robot light gradient (dynamic via JS) -->
        <radialGradient id="robotLightGrad" cx="50%" cy="30%" r="60%" gradientUnits="objectBoundingBox">
          <stop offset="0%" stop-color="#aed301" stop-opacity="0.18" />
          <stop offset="100%" stop-color="#1e1e35" stop-opacity="0" />
        </radialGradient>
        <!-- Screen glow -->
        <radialGradient id="screenGlow" cx="50%" cy="50%" r="50%" gradientUnits="objectBoundingBox">
          <stop offset="0%" stop-color="#aed301" stop-opacity="0.12" />
          <stop offset="100%" stop-color="#0a0a18" stop-opacity="0" />
        </radialGradient>
        <!-- Drop shadow filter for laser -->
        <filter id="laserGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
        <!-- Robot eye glow -->
        <filter id="eyeGlow" x="-80%" y="-80%" width="360%" height="360%">
          <feGaussianBlur stdDeviation="3" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <!-- ═══════════════════════════════════════════
           MacBook SVG (isometric-ish, 15° Y tilt)
           positioned on the right side
           ═══════════════════════════════════════════ -->
      <g id="macbook" transform="translate(180, 60)">
        <!-- Lid shadow -->
        <ellipse cx="130" cy="175" rx="110" ry="8" fill="rgba(0,0,0,0.35)" />

        <!-- Screen lid -->
        <g id="macbook-lid">
          <!-- Lid back panel -->
          <path d="M15,0 L245,0 L245,155 L15,155 Z"
                fill="#1a1a2e"
                stroke="#2a2a45"
                stroke-width="1.5" />
          <!-- Lid front face (slight 3D effect) -->
          <path d="M10,5 L250,5 L250,160 L10,160 Z"
                fill="#17172a"
                stroke="#252535"
                stroke-width="1" />
          <!-- Screen bezel -->
          <rect x="18" y="12" width="224" height="136" rx="3"
                fill="#0a0a18"
                stroke="#1e1e35"
                stroke-width="1" />
          <!-- Screen face (display) -->
          <rect x="22" y="16" width="216" height="128" rx="2"
                fill="#080812" />
          <!-- Screen ambient glow -->
          <rect x="22" y="16" width="216" height="128" rx="2"
                fill="url(#screenGlow)"
                opacity="0.8" />

          <!-- Screen content: ASCII / UI lines in accent color -->
          <g font-family="'Courier New', monospace" font-size="7" fill="#aed301" opacity="0.75">
            <text x="30" y="34">$ prvni-pozice --mode ai</text>
            <text x="30" y="46" opacity="0.5">▶ Inicializace AI modulu...</text>
            <text x="30" y="58">▶ GEO engine: <tspan fill="#01d3ae">aktivní</tspan></text>
            <text x="30" y="70" opacity="0.6">▶ SEO analýza: <tspan fill="#aed301">OK</tspan></text>
            <text x="30" y="90" opacity="0.4">───────────────────────────</text>
            <text x="30" y="102">STATUS: <tspan fill="#aed301" font-weight="bold">ONLINE</tspan></text>
            <text x="30" y="114" opacity="0.5">QUERIES: 2,847 / day</text>
            <text x="30" y="126" opacity="0.4">MODEL: GPT-4o + Gemini 2.0</text>
          </g>

          <!-- Blinking cursor -->
          <rect x="30" y="133" width="5" height="9" fill="#aed301" rx="1">
            <animate attributeName="opacity" values="1;0;1" dur="1.1s" repeatCount="indefinite" />
          </rect>

          <!-- Webcam dot -->
          <circle cx="130" cy="8" r="2" fill="#252535" />
          <circle cx="130" cy="8" r="1" fill="#1a3a1a" />
        </g>

        <!-- Base / body of MacBook -->
        <g id="macbook-base">
          <!-- Hinge area -->
          <rect x="10" y="158" width="240" height="6" rx="1" fill="#1e1e32" />
          <!-- Base top surface -->
          <path d="M5,164 L255,164 L260,194 L0,194 Z"
                fill="#16162a"
                stroke="#232338"
                stroke-width="1" />
          <!-- Base face -->
          <rect x="0" y="194" width="260" height="14" rx="2"
                fill="#1a1a2e"
                stroke="#252540"
                stroke-width="1" />

          <!-- Keyboard area hint -->
          <g opacity="0.35">
            <!-- Key rows (simplified) -->
            <rect x="12" y="168" width="236" height="3" rx="1" fill="#2a2a45" />
            <rect x="12" y="173" width="236" height="3" rx="1" fill="#252540" />
            <rect x="12" y="178" width="220" height="3" rx="1" fill="#222238" />
            <rect x="22" y="183" width="200" height="3" rx="1" fill="#1e1e38" />
            <!-- Trackpad -->
            <rect x="88" y="188" width="84" height="3" rx="1" fill="#252540" />
          </g>

          <!-- Apple logo-ish mark on lid (very subtle) -->
          <circle cx="130" cy="80" r="10" fill="none" stroke="rgba(174,211,1,0.06)" stroke-width="1" />
        </g>
      </g>

      <!-- ═══════════════════════════════════════════
           Robot SVG (humanoid, left side of scene)
           ═══════════════════════════════════════════ -->
      <g id="robot-body" style="transform-origin: 90px 220px; transform: rotate(0deg);">

        <!-- Body light overlay (dynamic gradient) -->
        <rect x="20" y="80" width="140" height="220" fill="url(#robotLightGrad)" />

        <!-- ── Legs (lower, partially visible) ── -->
        <g id="robot-legs" opacity="0.7">
          <!-- Left leg -->
          <rect x="52" y="260" width="28" height="55" rx="5" fill="#1a1a2e" stroke="#252545" stroke-width="1" />
          <rect x="54" y="310" width="32" height="10" rx="4" fill="#161628" stroke="#222238" stroke-width="1" />
          <!-- Right leg -->
          <rect x="100" y="260" width="28" height="55" rx="5" fill="#1a1a2e" stroke="#252545" stroke-width="1" />
          <rect x="98" y="310" width="32" height="10" rx="4" fill="#161628" stroke="#222238" stroke-width="1" />
        </g>

        <!-- ── Torso ── -->
        <g id="robot-torso" style="transform-origin: 90px 210px; transform: rotate(0deg);">
          <!-- Torso shape (trapezoidal) -->
          <path d="M45,265 L50,160 L130,160 L135,265 Z"
                fill="#1e1e35"
                stroke="#2a2a45"
                stroke-width="1.5" />
          <!-- Torso panel detail -->
          <rect x="62" y="178" width="56" height="60" rx="6"
                fill="#161628"
                stroke="#252545"
                stroke-width="1" />
          <!-- Torso LED indicators -->
          <circle cx="72" cy="192" r="4" fill="#aed301" opacity="0.8">
            <animate attributeName="opacity" values="0.8;0.3;0.8" dur="2.3s" repeatCount="indefinite" />
          </circle>
          <circle cx="84" cy="192" r="4" fill="#01d3ae" opacity="0.6">
            <animate attributeName="opacity" values="0.6;0.2;0.6" dur="3.1s" repeatCount="indefinite" />
          </circle>
          <circle cx="96" cy="192" r="4" fill="#aed301" opacity="0.4">
            <animate attributeName="opacity" values="0.4;0.1;0.4" dur="1.8s" repeatCount="indefinite" />
          </circle>
          <!-- Torso circuit lines -->
          <line x1="68" y1="210" x2="112" y2="210" stroke="rgba(174,211,1,0.2)" stroke-width="1" />
          <line x1="68" y1="217" x2="100" y2="217" stroke="rgba(174,211,1,0.15)" stroke-width="1" />
          <line x1="68" y1="224" x2="108" y2="224" stroke="rgba(174,211,1,0.1)" stroke-width="1" />

          <!-- ── Shoulders ── -->
          <g id="robot-shoulders" style="transform-origin: 90px 165px; transform: rotate(0deg);">
            <!-- Left shoulder -->
            <path d="M50,160 L20,170 L18,200 L45,205 L45,160 Z"
                  fill="#1e1e35"
                  stroke="#2a2a45"
                  stroke-width="1.5" />
            <!-- Left arm -->
            <rect x="8" y="200" width="22" height="60" rx="8"
                  fill="#1a1a2e"
                  stroke="#252545"
                  stroke-width="1" />
            <!-- Left hand -->
            <ellipse cx="19" cy="266" rx="11" ry="8" fill="#161628" stroke="#222238" stroke-width="1" />

            <!-- Right shoulder -->
            <path d="M130,160 L160,170 L162,200 L135,205 L135,160 Z"
                  fill="#1e1e35"
                  stroke="#2a2a45"
                  stroke-width="1.5" />
            <!-- Right arm -->
            <rect x="150" y="200" width="22" height="60" rx="8"
                  fill="#1a1a2e"
                  stroke="#252545"
                  stroke-width="1" />
            <!-- Right hand -->
            <ellipse cx="161" cy="266" rx="11" ry="8" fill="#161628" stroke="#222238" stroke-width="1" />

            <!-- Neck -->
            <rect x="78" y="136" width="24" height="26" rx="5"
                  fill="#1a1a2e"
                  stroke="#252545"
                  stroke-width="1" />

            <!-- ── Head ── -->
            <g id="robot-head" style="transform-origin: 90px 140px; transform: rotate(0deg);">
              <!-- Head main shape -->
              <rect x="52" y="78" width="76" height="60" rx="10"
                    fill="#1e1e35"
                    stroke="#2a2a45"
                    stroke-width="2" />
              <!-- Head top detail -->
              <rect x="68" y="72" width="44" height="10" rx="5"
                    fill="#1a1a2e"
                    stroke="#252545"
                    stroke-width="1" />
              <!-- Antenna -->
              <line x1="90" y1="72" x2="90" y2="52" stroke="#2a2a45" stroke-width="2" />
              <circle cx="90" cy="49" r="5" fill="#1e1e35" stroke="#aed301" stroke-width="1.5">
                <animate attributeName="opacity" values="1;0.4;1" dur="2.5s" repeatCount="indefinite" />
              </circle>

              <!-- Visor / face panel -->
              <rect x="58" y="88" width="64" height="36" rx="6"
                    fill="#0a0a18"
                    stroke="#252545"
                    stroke-width="1" />

              <!-- Eyes group -->
              <g id="robot-eyes">
                <!-- Left eye -->
                <ellipse cx="74" cy="106" rx="9" ry="7"
                         fill="#0e0e1e"
                         stroke="#aed301"
                         stroke-width="1.5"
                         filter="url(#eyeGlow)" />
                <ellipse cx="74" cy="106" rx="5" ry="4" fill="#aed301" opacity="0.9">
                  <animate attributeName="opacity" values="0.9;0.5;0.9" dur="3s" repeatCount="indefinite" />
                </ellipse>
                <circle cx="74" cy="106" r="2" fill="#ffffff" opacity="0.8" />

                <!-- Right eye -->
                <ellipse cx="106" cy="106" rx="9" ry="7"
                         fill="#0e0e1e"
                         stroke="#aed301"
                         stroke-width="1.5"
                         filter="url(#eyeGlow)" />
                <ellipse cx="106" cy="106" rx="5" ry="4" fill="#aed301" opacity="0.9">
                  <animate attributeName="opacity" values="0.9;0.5;0.9" dur="3s" begin="0.4s" repeatCount="indefinite" />
                </ellipse>
                <circle cx="106" cy="106" r="2" fill="#ffffff" opacity="0.8" />
              </g>

              <!-- Mouth / speaker grille -->
              <g stroke="rgba(174,211,1,0.3)" stroke-width="1">
                <line x1="68" y1="116" x2="112" y2="116" />
                <line x1="70" y1="120" x2="110" y2="120" />
                <line x1="72" y1="124" x2="108" y2="124" />
              </g>

              <!-- Head side panels -->
              <rect x="52" y="90" width="6" height="20" rx="2"
                    fill="#161628" stroke="#1e1e35" stroke-width="1" />
              <rect x="122" y="90" width="6" height="20" rx="2"
                    fill="#161628" stroke="#1e1e35" stroke-width="1" />
            </g>
            <!-- /robot-head -->
          </g>
          <!-- /robot-shoulders -->
        </g>
        <!-- /robot-torso -->

        <!-- ── Laser beams from eyes ── -->
        <g id="robot-lasers" filter="url(#laserGlow)">
          <!-- Left eye laser → MacBook screen center -->
          <line id="laser-left"
                x1="74" y1="106"
                x2="310" y2="140"
                stroke="#aed301"
                stroke-width="1.5"
                stroke-opacity="0.6"
                stroke-dasharray="4 3"
                class="laser-beam">
            <animate attributeName="stroke-opacity" values="0.6;0.2;0.6" dur="2s" repeatCount="indefinite" />
          </line>
          <!-- Right eye laser → MacBook screen center -->
          <line id="laser-right"
                x1="106" y1="106"
                x2="310" y2="140"
                stroke="#aed301"
                stroke-width="1.5"
                stroke-opacity="0.6"
                stroke-dasharray="4 3"
                class="laser-beam">
            <animate attributeName="stroke-opacity" values="0.6;0.2;0.6" dur="2s" begin="0.3s" repeatCount="indefinite" />
          </line>
        </g>

      </g>
      <!-- /robot-body -->

    </svg>
  </div>

  <!-- Content (left side) -->
  <div class="container hero-content" data-reveal>
    <div class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      AI-first znalosti pro rok 2026
    </div>

    <h1 class="hero-title">
      Budoucnost vyhledávání<br />
      <span class="hero-accent">začíná teď</span>
    </h1>

    <p class="hero-lead">
      Blog o SEO, GEO a umělé inteligenci od týmu <strong>První pozice</strong>.<br />
      Praktické znalosti pro firmy, které nechtějí být překvapeny.
    </p>

    <div class="hero-actions">
      <a href="/ai/" class="btn-primary">
        Začít číst
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="/geo/" class="btn-ghost">Sekce GEO →</a>
    </div>

    <!-- Stats -->
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">2</span>
        <span class="stat-label">Sekce</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">AI</span>
        <span class="stat-label">Zaměření</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Prakticky</span>
      </div>
    </div>
  </div>
</section>

<script>
  // prefers-reduced-motion guard
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const heroSection = document.querySelector('.hero') as HTMLElement | null;
  const robotBody = document.getElementById('robot-body') as SVGGElement | null;
  const robotTorso = document.getElementById('robot-torso') as SVGGElement | null;
  const robotShoulders = document.getElementById('robot-shoulders') as SVGGElement | null;
  const robotHead = document.getElementById('robot-head') as SVGGElement | null;
  const laserLeft = document.getElementById('laser-left') as SVGLineElement | null;
  const laserRight = document.getElementById('laser-right') as SVGLineElement | null;
  const robotLightGrad = document.getElementById('robotLightGrad') as SVGRadialGradientElement | null;
  const macbook = document.getElementById('macbook') as SVGGElement | null;

  // Mouse tracking
  if (!prefersReduced && heroSection) {
    let cx = 0;
    let cy = 0;

    heroSection.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = heroSection.getBoundingClientRect();
      // Normalize -1..1 relative to center
      cx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
      cy = ((e.clientY - rect.top) / rect.height - 0.5) * 2;

      // Robot body: slight lean
      if (robotBody) {
        robotBody.style.transform = `rotate(${cx * 3}deg) translateX(${cx * 2}px)`;
        robotBody.style.transition = 'transform 300ms cubic-bezier(0.22,1,0.36,1)';
      }
      // Torso: follow mouse
      if (robotTorso) {
        robotTorso.style.transform = `rotate(${cx * 2}deg)`;
        robotTorso.style.transition = 'transform 300ms cubic-bezier(0.22,1,0.36,1)';
      }
      // Shoulders: counter-rotation
      if (robotShoulders) {
        robotShoulders.style.transform = `rotate(${cx * -1}deg)`;
        robotShoulders.style.transition = 'transform 250ms cubic-bezier(0.22,1,0.36,1)';
      }
      // Head: follows more closely
      if (robotHead) {
        robotHead.style.transform = `rotate(${cx * 8}deg) translateY(${cy * 3}px)`;
        robotHead.style.transition = 'transform 150ms cubic-bezier(0.22,1,0.36,1)';
      }

      // Dynamic lighting: update gradient center
      if (robotLightGrad) {
        const gx = (50 + cx * 25).toFixed(1) + '%';
        const gy = (30 + cy * 20).toFixed(1) + '%';
        const stops = robotLightGrad.querySelectorAll('stop');
        robotLightGrad.setAttribute('cx', gx);
        robotLightGrad.setAttribute('cy', gy);
      }

      // Laser targeting: move laser endpoints toward cursor position in SVG coords
      const svgEl = document.getElementById('heroSceneSvg') as SVGSVGElement | null;
      if (svgEl && laserLeft && laserRight) {
        const svgRect = svgEl.getBoundingClientRect();
        const svgW = 460;
        const svgH = 340;
        const targetX = ((e.clientX - svgRect.left) / svgRect.width) * svgW;
        const targetY = ((e.clientY - svgRect.top) / svgRect.height) * svgH;
        // Blend toward cursor (capped to screen area)
        const blendX = Math.max(150, Math.min(450, targetX));
        const blendY = Math.max(20, Math.min(320, targetY));
        laserLeft.setAttribute('x2', String(blendX));
        laserLeft.setAttribute('y2', String(blendY));
        laserRight.setAttribute('x2', String(blendX));
        laserRight.setAttribute('y2', String(blendY));
      }
    });

    // Reset on mouse leave
    heroSection.addEventListener('mouseleave', () => {
      if (robotBody) robotBody.style.transform = '';
      if (robotTorso) robotTorso.style.transform = '';
      if (robotShoulders) robotShoulders.style.transform = '';
      if (robotHead) robotHead.style.transform = '';
      // Reset lasers to MacBook screen
      if (laserLeft) { laserLeft.setAttribute('x2', '310'); laserLeft.setAttribute('y2', '140'); }
      if (laserRight) { laserRight.setAttribute('x2', '310'); laserRight.setAttribute('y2', '140'); }
    });
  }

  // Scroll → MacBook tilt
  if (!prefersReduced && macbook) {
    const heroObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          // Activate MacBook tilt animation based on scroll
          const onScroll = () => {
            const heroEl = document.querySelector('.hero') as HTMLElement | null;
            if (!heroEl) return;
            const heroH = heroEl.offsetHeight;
            const scrolled = window.scrollY;
            const progress = Math.min(scrolled / heroH, 1);
            if (macbook) {
              const tilt = progress * 8;
              macbook.style.transform = `translate(180px, 60px) rotateX(${tilt}deg)`;
              macbook.style.transition = 'transform 200ms linear';

              // Lasers: at >30% scroll, drift to viewport center
              if (progress > 0.3 && laserLeft && laserRight) {
                laserLeft.setAttribute('x2', '230');
                laserLeft.setAttribute('y2', '170');
                laserRight.setAttribute('x2', '230');
                laserRight.setAttribute('y2', '170');
              } else if (progress <= 0.3 && laserLeft && laserRight) {
                laserLeft.setAttribute('x2', '310');
                laserLeft.setAttribute('y2', '140');
                laserRight.setAttribute('x2', '310');
                laserRight.setAttribute('y2', '140');
              }
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
        });
      },
      { threshold: 0.1 }
    );
    const heroEl = document.querySelector('.hero');
    if (heroEl) heroObserver.observe(heroEl);
  }
</script>

<style>
  /* ── Hero container ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  /* ── Nebula layers ── */
  .hero-nebula {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .nebula-layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    animation: nebulaPulse 12s ease-in-out infinite alternate;
  }

  .nebula-1 {
    width: 70%;
    height: 60%;
    top: -10%;
    left: 20%;
    background: radial-gradient(ellipse, rgba(174, 211, 1, 0.07) 0%, transparent 70%);
    animation-delay: 0s;
  }

  .nebula-2 {
    width: 50%;
    height: 50%;
    bottom: 0;
    right: -10%;
    background: radial-gradient(ellipse, rgba(1, 211, 174, 0.05) 0%, transparent 70%);
    animation-delay: -4s;
    animation-duration: 16s;
  }

  .nebula-3 {
    width: 40%;
    height: 40%;
    bottom: 10%;
    left: -5%;
    background: radial-gradient(ellipse, rgba(174, 211, 1, 0.04) 0%, transparent 70%);
    animation-delay: -8s;
    animation-duration: 20s;
  }

  @keyframes nebulaPulse {
    0%   { opacity: 0.6; transform: scale(1); }
    100% { opacity: 1;   transform: scale(1.08); }
  }

  /* ── Dot grid ── */
  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(174, 211, 1, 0.12) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Hero scene (MacBook + Robot) ── */
  .hero-scene {
    position: absolute;
    right: 3%;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(300px, 40vw, 500px);
    opacity: 0.85;
    pointer-events: none;
    will-change: transform;
  }

  @media (max-width: 900px) {
    .hero-scene {
      width: 260px;
      right: -2%;
      opacity: 0.4;
    }
  }

