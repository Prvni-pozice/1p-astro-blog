---
import { Image } from 'astro:assets';
import bot from '../../assets/hero/bot.png';
import mac from '../../assets/hero/mac.png';
---

<section class="hero" id="heroSection" aria-label="Úvod">
  <!-- Animated nebula background -->
  <div class="hero-nebula" aria-hidden="true">
    <div class="nebula-layer nebula-1"></div>
    <div class="nebula-layer nebula-2"></div>
    <div class="nebula-layer nebula-3"></div>
  </div>
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- Mac laptop layer (za robotem, nižší z-index) -->
  <div class="hero-mac" id="heroMac" aria-hidden="true">
    <div class="mac-inner">
      <Image
        src={mac}
        alt=""
        width={932}
        height={656}
        format="webp"
        quality={85}
        loading="eager"
        decoding="async"
        class="mac-img"
      />
      <!-- Screen overlay — terminal text -->
      <div class="mac-screen" id="macScreen">
        <div class="screen-scanlines"></div>
        <div class="screen-content-wrap">
          <div class="screen-lines" id="screenLines">
            <div class="sl">$ geo-scan --domain prvni-pozice.com</div>
            <div class="sl sl-dim">▶ Initializing AI visibility check...</div>
            <div class="sl">  GEO score <span class="sl-bar">████████████░░</span> 94/100</div>
            <div class="sl sl-ok">  ChatGPT citations      ↑ 128%</div>
            <div class="sl sl-ok">  Perplexity AI          found ✓</div>
            <div class="sl sl-ok">  Google AI Overview     active ✓</div>
            <div class="sl sl-ok">  Bing Copilot           indexed ✓</div>
            <div class="sl sl-dim">▶ Entity analysis...</div>
            <div class="sl">  Entity strength        <span class="sl-val">0.94</span></div>
            <div class="sl sl-ok">  Schema: BlogPosting    VALID ✓</div>
            <div class="sl sl-ok">  FAQ Schema             VALID ✓</div>
            <div class="sl">  RAG signal             <span class="sl-hi">HIGH</span></div>
            <div class="sl">  LLM training data      included</div>
            <div class="sl sl-dim">▶ SEO cross-check...</div>
            <div class="sl">  SERP position avg      <span class="sl-val">3.2</span></div>
            <div class="sl sl-ok">  Core Web Vitals        PASS ✓</div>
            <div class="sl">  Brand mentions/mo      <span class="sl-val">1,284</span></div>
            <div class="sl sl-sep">  ──────────────────────────</div>
            <div class="sl sl-ok">▶ GEO audit complete ✓</div>
            <div class="sl sl-dim">  next scan in 24h...</div>
            <!-- Seamless loop copy -->
            <div class="sl">$ geo-scan --domain prvni-pozice.com</div>
            <div class="sl sl-dim">▶ Initializing AI visibility check...</div>
            <div class="sl">  GEO score <span class="sl-bar">████████████░░</span> 94/100</div>
            <div class="sl sl-ok">  ChatGPT citations      ↑ 128%</div>
            <div class="sl sl-ok">  Perplexity AI          found ✓</div>
            <div class="sl sl-ok">  Google AI Overview     active ✓</div>
            <div class="sl sl-ok">  Bing Copilot           indexed ✓</div>
            <div class="sl sl-dim">▶ Entity analysis...</div>
            <div class="sl">  Entity strength        <span class="sl-val">0.94</span></div>
            <div class="sl sl-ok">  Schema: BlogPosting    VALID ✓</div>
            <div class="sl sl-ok">  FAQ Schema             VALID ✓</div>
            <div class="sl">  RAG signal             <span class="sl-hi">HIGH</span></div>
            <div class="sl">  LLM training data      included</div>
            <div class="sl sl-dim">▶ SEO cross-check...</div>
            <div class="sl">  SERP position avg      <span class="sl-val">3.2</span></div>
            <div class="sl sl-ok">  Core Web Vitals        PASS ✓</div>
            <div class="sl">  Brand mentions/mo      <span class="sl-val">1,284</span></div>
            <div class="sl sl-sep">  ──────────────────────────</div>
            <div class="sl sl-ok">▶ GEO audit complete ✓</div>
            <div class="sl sl-dim">  next scan in 24h...</div>
          </div>
        </div>
      </div>
      <!-- Odlesk displeje -->
      <div class="mac-screen-glow" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Robot layer (vpředu, vyšší z-index) -->
  <div class="hero-bot" id="heroBot" aria-hidden="true">
    <div class="bot-inner">
      <Image
        src={bot}
        alt=""
        width={528}
        height={749}
        format="webp"
        quality={85}
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="bot-img"
      />
      <!-- Jemné oční záře (pozice 28% a 42% zleva, pohybují se za kurzorem) -->
      <div class="bot-eye bot-eye-l" id="botEyeL" aria-hidden="true"></div>
      <div class="bot-eye bot-eye-r" id="botEyeR" aria-hidden="true"></div>
      <!-- Laser světelné kužely — CSS rotate na celém SVG, spolehlivé -->
      <svg id="botLasers" class="bot-lasers" viewBox="0 0 528 749"
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="coneGradL" x1="0.5" y1="0" x2="0.5" y2="1">
            <stop offset="0%" stop-color="#aed301" stop-opacity="0.18"/>
            <stop offset="70%" stop-color="#aed301" stop-opacity="0.05"/>
            <stop offset="100%" stop-color="#aed301" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="coneGradR" x1="0.5" y1="0" x2="0.5" y2="1">
            <stop offset="0%" stop-color="#aed301" stop-opacity="0.18"/>
            <stop offset="70%" stop-color="#aed301" stop-opacity="0.05"/>
            <stop offset="100%" stop-color="#aed301" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <!-- Kužele mířící přímo dolů — směr řídí CSS rotate na celém SVG -->
        <path d="M 148 165 L 80 749 L 216 749 Z" fill="url(#coneGradL)">
          <animate attributeName="opacity" values="1;0.28;1" dur="3.8s" repeatCount="indefinite"/>
        </path>
        <path d="M 222 165 L 154 749 L 290 749 Z" fill="url(#coneGradR)">
          <animate attributeName="opacity" values="1;0.28;1" dur="3.8s" begin="0.9s" repeatCount="indefinite"/>
        </path>
      </svg>
      <!-- Kurzorem řízený světelný odlesk -->
      <div class="bot-light" id="botLight" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Text content (left side) -->
  <div class="container hero-content" data-reveal>
    <div class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      AI-first znalosti pro rok 2026
    </div>

    <h1 class="hero-title">
      Budoucnost vyhledávání<br />
      <span class="hero-accent">začíná teď</span>
    </h1>

    <p class="hero-lead">
      Blog o SEO, GEO a umělé inteligenci od týmu <strong>První pozice</strong>.<br />
      Praktické znalosti pro firmy, které nechtějí být překvapeny.
    </p>

    <div class="hero-actions">
      <a href="/ai/" class="btn-primary">
        Začít číst
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="/geo/" class="btn-ghost">Sekce GEO →</a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">2</span>
        <span class="stat-label">Sekce</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">AI</span>
        <span class="stat-label">Zaměření</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Prakticky</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  /* ── Nebula ── */
  .hero-nebula { position: absolute; inset: 0; pointer-events: none; }
  .nebula-layer {
    position: absolute; border-radius: 50%;
    filter: blur(80px); mix-blend-mode: screen;
    animation: nebulaPulse 12s ease-in-out infinite alternate;
  }
  .nebula-1 { width: 70%; height: 60%; top: -10%; left: 20%; background: radial-gradient(ellipse, rgba(174,211,1,0.07) 0%, transparent 70%); }
  .nebula-2 { width: 50%; height: 50%; bottom: 0; right: -10%; background: radial-gradient(ellipse, rgba(1,211,174,0.05) 0%, transparent 70%); animation-delay: -4s; animation-duration: 16s; }
  .nebula-3 { width: 40%; height: 40%; bottom: 10%; left: -5%; background: radial-gradient(ellipse, rgba(174,211,1,0.04) 0%, transparent 70%); animation-delay: -8s; animation-duration: 20s; }
  @keyframes nebulaPulse { 0% { opacity: 0.6; transform: scale(1); } 100% { opacity: 1; transform: scale(1.08); } }

  /* ── Dot grid ── */
  .hero-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(174,211,1,0.12) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Robot layer ── */
  .hero-bot {
    position: absolute;
    right: 2%;
    bottom: 0;
    width: clamp(200px, 26vw, 380px);
    aspect-ratio: 528 / 749;
    z-index: 3;
    pointer-events: none;
    /* Parallax + 3D mouse tracking — CSS vars z motion.js */
    transform:
      translateY(var(--bot-parallax, 0px))
      perspective(900px)
      rotateX(var(--head-rx, 0deg))
      rotateY(var(--head-ry, 0deg));
    transition: transform 200ms ease-out;
    will-change: transform;
  }

  .bot-inner {
    position: relative;
    width: 100%;
    height: 100%;
    /* Jemná float animace — CSS `translate` nekonflikuje s `transform` */
    animation: botFloat 5s ease-in-out infinite;
  }

  @keyframes botFloat {
    0%, 100% { translate: 0 0px; }
    50%       { translate: 0 -12px; }
  }

  .bot-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Vignette maska — bílé pozadí zmizí do tmavého hero pozadí */
    mask-image: radial-gradient(ellipse 70% 82% at 50% 42%,
      black 38%, rgba(0,0,0,0.75) 58%, transparent 78%);
    -webkit-mask-image: radial-gradient(ellipse 70% 82% at 50% 42%,
      black 38%, rgba(0,0,0,0.75) 58%, transparent 78%);
  }

  /* ── Oční záře ── */
  .bot-eye {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(174, 211, 1, 0.7);
    box-shadow:
      0 0 5px 2px rgba(174, 211, 1, 0.45),
      0 0 12px 6px rgba(174, 211, 1, 0.12);
    transform: translate(-50%, -50%);
    animation: eyePulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }
  .bot-eye-l { left: 28%; top: 22%; }
  .bot-eye-r { left: 42%; top: 22%; animation-delay: 0.5s; }

  @keyframes eyePulse {
    0%, 100% {
      opacity: 0.75;
      box-shadow: 0 0 5px 2px rgba(174,211,1,0.45), 0 0 12px 6px rgba(174,211,1,0.12);
    }
    50% {
      opacity: 0.3;
      box-shadow: 0 0 2px 1px rgba(174,211,1,0.2), 0 0 6px 3px rgba(174,211,1,0.06);
    }
  }

  /* ── Laserové světelné kužely ── */
  .bot-lasers {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    /* JS nastaví rotate(); origin = střed mezi očima */
    transform-origin: 35% 22%;
    transition: transform 0.25s ease-out;
  }

  /* ── Kurzorový odlesk ── */
  .bot-light {
    position: absolute;
    inset: 0;
    mix-blend-mode: soft-light;
    pointer-events: none;
    transition: background 0.15s ease;
  }

  /* ── Mac vrstva ── */
  .hero-mac {
    position: absolute;
    right: 17%;
    bottom: 2%;
    width: clamp(240px, 36vw, 510px);
    aspect-ratio: 932 / 656;
    z-index: 2;
    pointer-events: none;
    transform: translateY(var(--mac-parallax, 0px));
    will-change: transform;
  }

  .mac-inner {
    position: relative;
    width: 100%;
    height: 100%;
    animation: macFloat 6.5s ease-in-out 1.6s infinite;
  }

  @keyframes macFloat {
    0%, 100% { translate: 0 0px; }
    50%       { translate: 0 -8px; }
  }

  .mac-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Vignette maska — bílé pozadí zmizí */
    mask-image: radial-gradient(ellipse 82% 78% at 50% 44%,
      black 38%, rgba(0,0,0,0.72) 58%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 82% 78% at 50% 44%,
      black 38%, rgba(0,0,0,0.72) 58%, transparent 80%);
  }

  /* ── Mac screen overlay — terminal text ── */
  .mac-screen {
    position: absolute;
    left: 11.3%;
    top: 8.8%;
    width: 51.5%;
    height: 57%;
    overflow: hidden;
    border-radius: 3px;
    background: #05080fe0;
    transform: perspective(280px) rotateX(3deg) rotateY(10deg) rotateZ(-6deg);
    pointer-events: none;
  }

  /* Jemný zelený odlesk pod displejem */
  .mac-screen-glow {
    position: absolute;
    left: 14%;
    top: 3%;
    width: 72%;
    height: 68%;
    background: radial-gradient(ellipse at 50% 90%,
      rgba(174, 211, 1, 0.055) 0%, transparent 65%);
    pointer-events: none;
  }

  /* Scanlines */
  .screen-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.07) 2px,
      rgba(0,0,0,0.07) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .screen-content-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    padding: 6% 8%;
  }

  /* Scrollující terminálový text — 2× obsah, seamless loop */
  .screen-lines {
    animation: screenScroll 16s linear infinite;
    will-change: transform;
  }

  @keyframes screenScroll {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  .sl {
    font-family: 'Courier New', 'Consolas', monospace;
    font-size: clamp(4.5px, 0.65vw, 7.5px);
    color: rgba(174, 211, 1, 0.8);
    line-height: 1.7;
    white-space: nowrap;
  }
  .sl-dim { color: rgba(174, 211, 1, 0.4); }
  .sl-ok  { color: rgba(1, 211, 174, 0.75); }
  .sl-hi  { color: #aed301; font-weight: bold; }
  .sl-val { color: rgba(255, 255, 255, 0.7); }
  .sl-bar { color: rgba(1, 211, 174, 0.6); }
  .sl-sep { color: rgba(174, 211, 1, 0.2); }

  /* ── Mobile ── */
  @media (max-width: 1100px) {
    .hero-bot { width: 240px; right: 0; }
    .hero-mac { right: 10%; width: clamp(200px, 28vw, 360px); }
    .mac-screen { display: none; }
  }
  @media (max-width: 800px) {
    .hero-bot { width: 200px; right: -3%; opacity: 0.55; }
    .hero-mac { display: none; }
  }
  @media (max-width: 540px) {
    .hero-bot { width: 160px; opacity: 0.3; right: -6%; }
  }

  /* ── Text content ── */
  .hero-content {
    position: relative;
    z-index: 10;
    padding-block: 4rem;
    max-width: 580px;
    margin-inline-start: 0;
    /* 2× levý padding oproti standardnímu containeru */
    padding-inline-start: clamp(2rem, 8vw, 4rem);
  }

  /* Na úzkých obrazovkách standardní zarovnání jako zbytek stránky */
  @media (max-width: 860px) {
    .hero-content {
      padding-inline-start: clamp(1rem, 4vw, 2rem);
      margin-inline: auto;
    }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: rgba(174,211,1,0.08);
    border: 1px solid rgba(174,211,1,0.2);
    border-radius: 100px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.75rem;
  }
  .badge-dot {
    width: 6px; height: 6px;
    background: var(--accent); border-radius: 50%;
    animation: badgeBlink 2s ease-in-out infinite;
  }
  @keyframes badgeBlink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }
  .hero-accent { color: var(--accent); }

  .hero-lead {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 54ch;
    margin-bottom: 2rem;
  }
  .hero-lead strong { color: var(--text); }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--accent); color: #08080d;
    font-family: var(--font-sans); font-weight: 700; font-size: 0.9375rem;
    padding: 0.7rem 1.5rem; border-radius: 100px; text-decoration: none;
    transition: background var(--duration) var(--ease), transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }
  .btn-primary:hover {
    background: var(--accent-hover); color: #08080d;
    transform: translateY(-2px); box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: var(--text-muted); font-family: var(--font-sans);
    font-weight: 500; font-size: 0.9375rem; text-decoration: none;
    padding: 0.7rem 0; transition: color var(--duration) var(--ease);
  }
  .btn-ghost:hover { color: var(--text); }

  .hero-stats {
    display: flex; align-items: center; gap: 1.5rem;
  }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .stat-value { font-family: var(--font-sans); font-size: 1.25rem; font-weight: 700; color: var(--accent); line-height: 1; }
  .stat-label { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-divider { width: 1px; height: 32px; background: var(--border); }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .nebula-layer    { animation: none !important; }
    .badge-dot       { animation: none !important; }
    .screen-lines    { animation: none !important; }
    .bot-inner       { animation: none !important; }
    .mac-inner       { animation: none !important; }
    .bot-eye         { animation: none !important; }
    .hero-bot        { transform: none !important; }
    .hero-mac        { transform: none !important; }
  }
</style>
