---
---

<section class="hero" id="heroSection" aria-label="Úvod">
  <!-- Animated nebula background -->
  <div class="hero-nebula" aria-hidden="true">
    <div class="nebula-layer nebula-1"></div>
    <div class="nebula-layer nebula-2"></div>
    <div class="nebula-layer nebula-3"></div>
  </div>

  <!-- Dot grid overlay -->
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- MacBook + Robot scene (right side) — vrstvený přístup pro reálné fotky -->
  <div class="hero-scene" id="heroScene" aria-hidden="true">

    <!-- Layer 1: Robot body + nohy
         REPLACE: src/assets/hero/robot-body.webp
         Rozměry: 800×1000 px, průhledné pozadí (PNG→WebP)
         Viz: docs/image-specs.md -->
    <div class="robot-layer robot-body" id="robotBody">
      <div class="ph ph-robot-body"></div>
    </div>

    <!-- Layer 2: Robot ramena + paže
         REPLACE: src/assets/hero/robot-arms.webp
         Rozměry: 800×600 px, průhledné pozadí
         Viz: docs/image-specs.md -->
    <div class="robot-layer robot-arms" id="robotArms">
      <div class="ph ph-robot-arms"></div>
    </div>

    <!-- Layer 3: Robot hlava (sleduje kurzor)
         REPLACE: src/assets/hero/robot-head.webp
         Rozměry: 400×500 px, průhledné pozadí
         Viz: docs/image-specs.md -->
    <div class="robot-layer robot-head" id="robotHead">
      <div class="ph ph-robot-head"></div>
    </div>

    <!-- Layer 4: MacBook (CSS 3D transform na scrollu)
         REPLACE: src/assets/hero/macbook.webp
         Rozměry: 1000×700 px, průhledné pozadí
         Viz: docs/image-specs.md -->
    <div class="macbook-layer" id="macbookLayer">
      <div class="ph ph-macbook"></div>

      <!-- Layer 5: Screen content HTML overlay — přesně na obrazovku MacBooku -->
      <div class="screen-content" aria-hidden="true">
        <div class="sc-line">$ prvni-pozice --mode ai</div>
        <div class="sc-line sc-dim">▶ GEO engine: <span class="sc-teal">aktivní</span></div>
        <div class="sc-line sc-dim">▶ SEO analýza: <span class="sc-accent">OK</span></div>
        <div class="sc-line sc-sep">────────────────────</div>
        <div class="sc-line">STATUS: <strong class="sc-accent">ONLINE</strong></div>
        <div class="sc-cursor"></div>
      </div>
    </div>

    <!-- Layer 6: Laser paprsky (SVG overlay, průhledný) -->
    <svg
      class="laser-svg"
      id="laserSvg"
      aria-hidden="true"
      viewBox="0 0 460 600"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <filter id="lGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>
      <!-- Levé oko → MacBook obrazovka -->
      <line id="laserLeft"
        x1="95" y1="160"
        x2="310" y2="255"
        stroke="#aed301" stroke-width="1.5"
        stroke-opacity="0.45" stroke-dasharray="4 3"
        filter="url(#lGlow)">
        <animate attributeName="stroke-opacity" values="0.45;0.15;0.45" dur="2s" repeatCount="indefinite"/>
      </line>
      <!-- Pravé oko → MacBook obrazovka -->
      <line id="laserRight"
        x1="128" y1="160"
        x2="310" y2="255"
        stroke="#aed301" stroke-width="1.5"
        stroke-opacity="0.45" stroke-dasharray="4 3"
        filter="url(#lGlow)">
        <animate attributeName="stroke-opacity" values="0.45;0.15;0.45" dur="2s" begin="0.3s" repeatCount="indefinite"/>
      </line>
    </svg>

    <!-- Layer 7: Dynamický světelný odlesk (sleduje kurzor) -->
    <div class="light-overlay" id="lightOverlay" aria-hidden="true"></div>
  </div>

  <!-- Content (left side) -->
  <div class="container hero-content" data-reveal>
    <div class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      AI-first znalosti pro rok 2026
    </div>

    <h1 class="hero-title">
      Budoucnost vyhledávání<br />
      <span class="hero-accent">začíná teď</span>
    </h1>

    <p class="hero-lead">
      Blog o SEO, GEO a umělé inteligenci od týmu <strong>První pozice</strong>.<br />
      Praktické znalosti pro firmy, které nechtějí být překvapeny.
    </p>

    <div class="hero-actions">
      <a href="/ai/" class="btn-primary">
        Začít číst
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="/geo/" class="btn-ghost">Sekce GEO →</a>
    </div>

    <!-- Stats -->
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">2</span>
        <span class="stat-label">Sekce</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">AI</span>
        <span class="stat-label">Zaměření</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Prakticky</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Hero container ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  /* ── Nebula layers ── */
  .hero-nebula {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .nebula-layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    animation: nebulaPulse 12s ease-in-out infinite alternate;
  }

  .nebula-1 {
    width: 70%; height: 60%;
    top: -10%; left: 20%;
    background: radial-gradient(ellipse, rgba(174,211,1,0.07) 0%, transparent 70%);
    animation-delay: 0s;
  }
  .nebula-2 {
    width: 50%; height: 50%;
    bottom: 0; right: -10%;
    background: radial-gradient(ellipse, rgba(1,211,174,0.05) 0%, transparent 70%);
    animation-delay: -4s; animation-duration: 16s;
  }
  .nebula-3 {
    width: 40%; height: 40%;
    bottom: 10%; left: -5%;
    background: radial-gradient(ellipse, rgba(174,211,1,0.04) 0%, transparent 70%);
    animation-delay: -8s; animation-duration: 20s;
  }

  @keyframes nebulaPulse {
    0%   { opacity: 0.6; transform: scale(1); }
    100% { opacity: 1;   transform: scale(1.08); }
  }

  /* ── Dot grid ── */
  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(174,211,1,0.12) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Hero scene — vrstvený kontejner ── */
  .hero-scene {
    position: absolute;
    right: 3%;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(300px, 42vw, 520px);
    aspect-ratio: 46 / 60;
    opacity: 0.9;
    pointer-events: none;
    /* transform se mění JS (scroll phase exit) */
  }

  /* Všechny vrstvy absolutně uvnitř scény */
  .robot-layer,
  .macbook-layer,
  .laser-svg,
  .light-overlay {
    position: absolute;
  }

  /* ── Layer 1: Robot tělo ── */
  .robot-body {
    left: 6%; top: 28%; width: 36%; height: 68%;
    z-index: 1;
    transform-origin: center bottom;
    /* JS: opacity + translateX při reveal */
    opacity: 0.08;
  }

  /* ── Layer 2: Robot ramena/paže ── */
  .robot-arms {
    left: 1%; top: 36%; width: 48%; height: 18%;
    z-index: 2;
    opacity: 0.08;
  }

  /* ── Layer 3: Robot hlava (cursor tracking) ── */
  .robot-head {
    left: 10%; top: 9%; width: 24%; height: 26%;
    z-index: 3;
    transform-origin: center bottom;
    opacity: 0.08;
  }

  /* ── Layer 4: MacBook ── */
  .macbook-layer {
    right: 0; top: 14%; width: 66%; height: 54%;
    z-index: 4;
    transform-origin: left center;
    /* JS: perspective(1200px) rotateY(-20deg) scale(1) → animace při scrollu */
    transform: perspective(1200px) rotateY(-20deg) scale(1);
    transition: transform 0.15s linear;
  }

  /* ── Layer 6: Laser SVG ── */
  .laser-svg {
    inset: 0; width: 100%; height: 100%;
    z-index: 5;
    overflow: visible;
  }

  /* ── Layer 7: Světelný odlesk ── */
  .light-overlay {
    inset: 0;
    z-index: 6;
    mix-blend-mode: soft-light;
    pointer-events: none;
    transition: background 0.15s ease;
  }

  /* ── Placeholder vizuály (dočasné, dokud nejsou reálné fotky) ── */
  .ph {
    width: 100%;
    height: 100%;
    border-radius: 8px;
  }

  /* Robot tělo — tvar trupu */
  .ph-robot-body {
    background:
      radial-gradient(circle 4px at 38% 28%, rgba(174,211,1,0.5) 0%, transparent 100%),
      radial-gradient(circle 4px at 54% 28%, rgba(1,211,174,0.4) 0%, transparent 100%),
      radial-gradient(circle 4px at 70% 28%, rgba(174,211,1,0.3) 0%, transparent 100%),
      linear-gradient(180deg, rgba(30,30,64,0.5) 22%, rgba(16,16,40,0.8) 22%, rgba(16,16,40,0.8) 68%, transparent 68%),
      linear-gradient(170deg, #1e2040 0%, #141525 55%, #0e0f1a 100%);
    clip-path: polygon(16% 0%, 84% 0%, 92% 8%, 96% 100%, 4% 100%, 8% 8%);
  }

  /* Robot ramena/paže */
  .ph-robot-arms {
    background: linear-gradient(180deg, #1c1d38 0%, #12131e 100%);
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.04);
  }

  /* Robot hlava — visor + oči */
  .ph-robot-head {
    background:
      radial-gradient(circle 5px at 30% 44%, rgba(174,211,1,0.55) 0%, rgba(174,211,1,0.1) 80%, transparent 100%),
      radial-gradient(circle 5px at 68% 44%, rgba(174,211,1,0.55) 0%, rgba(174,211,1,0.1) 80%, transparent 100%),
      linear-gradient(180deg, transparent 30%, rgba(8,10,24,0.88) 30%, rgba(8,10,24,0.88) 58%, transparent 58%),
      linear-gradient(135deg, #1e2040 0%, #16172a 100%);
    border-radius: 14px 14px 10px 10px;
    border: 1px solid rgba(174,211,1,0.08);
  }

  /* MacBook — lid + base */
  .ph-macbook {
    background:
      linear-gradient(180deg, #0a0a18 0%, #0a0a18 62%, #1e1e35 62%, #1e1e35 66%, #181828 66%, #181828 100%);
    border-radius: 8px 8px 4px 4px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  /* ── Screen content HTML overlay ── */
  .screen-content {
    position: absolute;
    top: 5%; left: 6%; right: 6%; height: 54%;
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    padding: 0.6em 0.8em;
    font-family: 'Courier New', monospace;
    font-size: clamp(5px, 0.8vw, 9px);
    color: rgba(174,211,1,0.75);
    overflow: hidden;
    z-index: 5;
    pointer-events: none;
  }

  .sc-line { line-height: 1.4; white-space: nowrap; }
  .sc-dim  { opacity: 0.55; }
  .sc-sep  { opacity: 0.25; }
  .sc-teal { color: #01d3ae; }
  .sc-accent { color: #aed301; font-weight: 700; }

  .sc-cursor {
    width: 5px; height: 9px;
    background: #aed301;
    border-radius: 1px;
    margin-top: 0.2em;
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

  /* ── Mobile: scéna menší, bez mouse trackingu ── */
  @media (max-width: 900px) {
    .hero-scene { width: 260px; right: -2%; opacity: 0.45; }
  }
  @media (max-width: 600px) {
    .hero-scene { width: 190px; opacity: 0.22; right: -5%; }
    .screen-content { display: none; }
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 4rem;
    max-width: 680px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: rgba(174,211,1,0.08);
    border: 1px solid rgba(174,211,1,0.2);
    border-radius: 100px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.75rem;
  }

  .badge-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: badgeBlink 2s ease-in-out infinite;
  }
  @keyframes badgeBlink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .hero-accent { color: var(--accent); display: inline; }

  .hero-lead {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 56ch;
    margin-bottom: 2rem;
  }
  .hero-lead strong { color: var(--text); }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: #08080d;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background var(--duration) var(--ease), transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    color: #08080d;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    padding: 0.7rem 0;
    transition: color var(--duration) var(--ease);
  }
  .btn-ghost:hover { color: var(--text); }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .nebula-layer { animation: none !important; }
    .sc-cursor    { animation: none !important; }
    .badge-dot    { animation: none !important; }
    .macbook-layer { transform: none !important; transition: none !important; }
    .robot-body, .robot-arms, .robot-head { opacity: 1 !important; transform: none !important; }
  }
</style>
