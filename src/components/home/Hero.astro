---
import { Image } from 'astro:assets';
import macBot from '../../assets/hero/mac-bot.png';
---

<section class="hero" id="heroSection" aria-label="Úvod">
  <!-- Animated nebula background -->
  <div class="hero-nebula" aria-hidden="true">
    <div class="nebula-layer nebula-1"></div>
    <div class="nebula-layer nebula-2"></div>
    <div class="nebula-layer nebula-3"></div>
  </div>
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- Scene: robot + MacBook -->
  <div class="hero-scene" id="heroScene" aria-hidden="true">

    <!-- Layer 1: Robot tělo + laptop (plný obrázek) -->
    <div class="scene-body" id="robotBody">
      <Image
        src={macBot}
        alt=""
        width={1200}
        height={896}
        format="webp"
        quality={85}
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="scene-img"
      />
    </div>

    <!-- Layer 2: Robot hlava (stejný obrázek, clip-path na hlavu — sleduje kurzor)
         Clip polygon odpovídá oblasti hlavy v obrázku 1344×768 -->
    <div class="scene-head" id="robotHead">
      <Image
        src={macBot}
        alt=""
        width={1200}
        height={896}
        format="webp"
        quality={85}
        loading="eager"
        decoding="async"
        class="scene-img"
      />
    </div>

    <!-- Layer 3: MacBook screen content overlay
         Pozicováno přes laptop screen v obrázku (~7–50% x, ~22–80% y) -->
    <div class="screen-overlay" id="screenOverlay" aria-hidden="true">
      <div class="screen-scanlines"></div>
      <div class="screen-content-wrap">
        <div class="screen-lines" id="screenLines">
          <!-- Obsah zopakován 2× pro plynulé smyčkování -->
          <div class="sl">$ geo-scan --domain prvni-pozice.com</div>
          <div class="sl sl-dim">▶ Initializing AI visibility check...</div>
          <div class="sl">  GEO score <span class="sl-bar">████████████░░</span> 94/100</div>
          <div class="sl sl-ok">  ChatGPT citations      ↑ 128%</div>
          <div class="sl sl-ok">  Perplexity AI          found ✓</div>
          <div class="sl sl-ok">  Google AI Overview     active ✓</div>
          <div class="sl sl-ok">  Bing Copilot           indexed ✓</div>
          <div class="sl sl-dim">▶ Entity analysis...</div>
          <div class="sl">  Entity strength        <span class="sl-val">0.94</span></div>
          <div class="sl sl-ok">  Schema: BlogPosting    VALID ✓</div>
          <div class="sl sl-ok">  FAQ Schema             VALID ✓</div>
          <div class="sl">  RAG signal             <span class="sl-hi">HIGH</span></div>
          <div class="sl">  LLM training data      included</div>
          <div class="sl sl-dim">▶ SEO cross-check...</div>
          <div class="sl">  SERP position avg      <span class="sl-val">3.2</span></div>
          <div class="sl sl-ok">  Core Web Vitals        PASS ✓</div>
          <div class="sl">  Brand mentions/mo      <span class="sl-val">1,284</span></div>
          <div class="sl sl-sep">  ──────────────────────────</div>
          <div class="sl sl-ok">▶ GEO audit complete ✓</div>
          <div class="sl sl-dim">  next scan in 24h...</div>
          <!-- Kopie pro seamless loop -->
          <div class="sl">$ geo-scan --domain prvni-pozice.com</div>
          <div class="sl sl-dim">▶ Initializing AI visibility check...</div>
          <div class="sl">  GEO score <span class="sl-bar">████████████░░</span> 94/100</div>
          <div class="sl sl-ok">  ChatGPT citations      ↑ 128%</div>
          <div class="sl sl-ok">  Perplexity AI          found ✓</div>
          <div class="sl sl-ok">  Google AI Overview     active ✓</div>
          <div class="sl sl-ok">  Bing Copilot           indexed ✓</div>
          <div class="sl sl-dim">▶ Entity analysis...</div>
          <div class="sl">  Entity strength        <span class="sl-val">0.94</span></div>
          <div class="sl sl-ok">  Schema: BlogPosting    VALID ✓</div>
          <div class="sl sl-ok">  FAQ Schema             VALID ✓</div>
          <div class="sl">  RAG signal             <span class="sl-hi">HIGH</span></div>
          <div class="sl">  LLM training data      included</div>
          <div class="sl sl-dim">▶ SEO cross-check...</div>
          <div class="sl">  SERP position avg      <span class="sl-val">3.2</span></div>
          <div class="sl sl-ok">  Core Web Vitals        PASS ✓</div>
          <div class="sl">  Brand mentions/mo      <span class="sl-val">1,284</span></div>
          <div class="sl sl-sep">  ──────────────────────────</div>
          <div class="sl sl-ok">▶ GEO audit complete ✓</div>
          <div class="sl sl-dim">  next scan in 24h...</div>
        </div>
      </div>
    </div>

    <!-- Layer 4: Laser paprsky z očí robota (SVG overlay) -->
    <svg class="laser-svg" id="laserSvg" aria-hidden="true"
      viewBox="0 0 700 400" preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="lGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>
      <!-- Oči robota ~63% a ~75% od leva, ~23% od hora → SVG coords -->
      <line id="laserLeft"
        x1="444" y1="92" x2="185" y2="127"
        stroke="#aed301" stroke-width="1.2" stroke-opacity="0.4"
        stroke-dasharray="3 4" filter="url(#lGlow)">
        <animate attributeName="stroke-opacity" values="0.4;0.1;0.4" dur="2.2s" repeatCount="indefinite"/>
      </line>
      <line id="laserRight"
        x1="524" y1="92" x2="185" y2="127"
        stroke="#aed301" stroke-width="1.2" stroke-opacity="0.4"
        stroke-dasharray="3 4" filter="url(#lGlow)">
        <animate attributeName="stroke-opacity" values="0.4;0.1;0.4" dur="2.2s" begin="0.4s" repeatCount="indefinite"/>
      </line>
    </svg>

    <!-- Layer 5: Dynamický světelný odlesk (cursor-reactive) -->
    <div class="light-overlay" id="lightOverlay" aria-hidden="true"></div>
  </div>

  <!-- Text content (left side) -->
  <div class="container hero-content" data-reveal>
    <div class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      AI-first znalosti pro rok 2026
    </div>

    <h1 class="hero-title">
      Budoucnost vyhledávání<br />
      <span class="hero-accent">začíná teď</span>
    </h1>

    <p class="hero-lead">
      Blog o SEO, GEO a umělé inteligenci od týmu <strong>První pozice</strong>.<br />
      Praktické znalosti pro firmy, které nechtějí být překvapeny.
    </p>

    <div class="hero-actions">
      <a href="/ai/" class="btn-primary">
        Začít číst
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="/geo/" class="btn-ghost">Sekce GEO →</a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">2</span>
        <span class="stat-label">Sekce</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">AI</span>
        <span class="stat-label">Zaměření</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Prakticky</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  /* ── Nebula ── */
  .hero-nebula { position: absolute; inset: 0; pointer-events: none; }
  .nebula-layer {
    position: absolute; border-radius: 50%;
    filter: blur(80px); mix-blend-mode: screen;
    animation: nebulaPulse 12s ease-in-out infinite alternate;
  }
  .nebula-1 { width: 70%; height: 60%; top: -10%; left: 20%; background: radial-gradient(ellipse, rgba(174,211,1,0.07) 0%, transparent 70%); }
  .nebula-2 { width: 50%; height: 50%; bottom: 0; right: -10%; background: radial-gradient(ellipse, rgba(1,211,174,0.05) 0%, transparent 70%); animation-delay: -4s; animation-duration: 16s; }
  .nebula-3 { width: 40%; height: 40%; bottom: 10%; left: -5%; background: radial-gradient(ellipse, rgba(174,211,1,0.04) 0%, transparent 70%); animation-delay: -8s; animation-duration: 20s; }
  @keyframes nebulaPulse { 0% { opacity: 0.6; transform: scale(1); } 100% { opacity: 1; transform: scale(1.08); } }

  /* ── Dot grid ── */
  .hero-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(174,211,1,0.12) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(0,0,0,0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Hero scene — 3D kontejner ── */
  .hero-scene {
    position: absolute;
    right: 0;
    top: 50%;
    width: clamp(340px, 46vw, 600px);
    aspect-ratio: 4 / 3;
    pointer-events: none;
    /* CSS vars z motion.js — scroll + mouse kombinace */
    transform:
      translateY(calc(-50% + var(--hero-exit-y, 0px)))
      perspective(1200px)
      rotateX(calc(var(--hero-rot-x, 1deg) + var(--hero-mouse-rx, 0deg)))
      rotateY(calc(var(--hero-rot-y, -5deg) + var(--hero-mouse-ry, 0deg)));
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Společné styly vrstev */
  .scene-body, .scene-head,
  .screen-overlay, .laser-svg, .light-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ── Layer 1: Tělo robota ── */
  .scene-body { z-index: 1; }

  .scene-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Layer 2: Hlava robota (clip + cursor tracking) ── */
  .scene-head {
    z-index: 2;
    /* Clip na oblast hlavy — přibližně 55-87% šířky, 0-49% výšky */
    clip-path: polygon(
      55% 0%, 87% 0%,
      92% 22%, 88% 42%,
      71% 49%, 54% 42%,
      50% 22%
    );
    /* Transform-origin na krk (71% šířky, 44% výšky prvku) */
    transform-origin: 71% 44%;
    transform:
      perspective(800px)
      rotateX(var(--head-rx, 0deg))
      rotateY(var(--head-ry, 0deg));
    transition: transform 150ms ease-out;
    will-change: transform;
  }

  /* ── Layer 3: Screen overlay — přes laptop screen ── */
  .screen-overlay {
    z-index: 3;
    /* Laptop screen v obrázku: cca left 9%, top 6%, width 35%, height 53% */
    left: 9%;
    top: 6%;
    width: 35%;
    height: 53%;
    inset: auto; /* reset inset, použijeme explicit positioning */
    overflow: hidden;
    border-radius: 4px;
    /* Sklon odpovídající úhlu laptopního displeje */
    transform: perspective(800px) rotateX(10deg) rotateY(-8deg);
    background: rgba(5, 8, 15, 0.82);
    mix-blend-mode: normal;
  }

  /* Scan-lines efekt */
  .screen-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .screen-content-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    padding: 6% 8%;
  }

  /* Scrollující text — 2× obsah, animace scrolluje přesně o 50% */
  .screen-lines {
    animation: screenScroll 14s linear infinite;
    will-change: transform;
  }

  @keyframes screenScroll {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  .sl {
    font-family: 'Courier New', 'Consolas', monospace;
    font-size: clamp(4.5px, 0.7vw, 8px);
    color: rgba(174, 211, 1, 0.8);
    line-height: 1.7;
    white-space: nowrap;
  }
  .sl-dim    { color: rgba(174, 211, 1, 0.4); }
  .sl-ok     { color: rgba(1, 211, 174, 0.75); }
  .sl-hi     { color: #aed301; font-weight: bold; }
  .sl-val    { color: rgba(255, 255, 255, 0.7); }
  .sl-bar    { color: rgba(1, 211, 174, 0.6); }
  .sl-sep    { color: rgba(174, 211, 1, 0.2); }

  /* ── Layer 4: Laser SVG ── */
  .laser-svg {
    z-index: 4;
    overflow: visible;
    pointer-events: none;
    inset: 0;
  }

  /* ── Layer 5: Světelný odlesk ── */
  .light-overlay {
    z-index: 5;
    mix-blend-mode: soft-light;
    pointer-events: none;
    transition: background 0.15s ease;
  }

  /* ── Mobile ── */
  @media (max-width: 1000px) {
    .hero-scene { width: 300px; right: -3%; opacity: 0.5; }
    .screen-overlay { display: none; }
  }
  @media (max-width: 640px) {
    .hero-scene { width: 220px; opacity: 0.25; right: -8%; }
  }

  /* ── Text content ── */
  .hero-content {
    position: relative;
    z-index: 10;
    padding-block: 4rem;
    max-width: 640px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: rgba(174,211,1,0.08);
    border: 1px solid rgba(174,211,1,0.2);
    border-radius: 100px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1.75rem;
  }
  .badge-dot {
    width: 6px; height: 6px;
    background: var(--accent); border-radius: 50%;
    animation: badgeBlink 2s ease-in-out infinite;
  }
  @keyframes badgeBlink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }
  .hero-accent { color: var(--accent); }

  .hero-lead {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 54ch;
    margin-bottom: 2rem;
  }
  .hero-lead strong { color: var(--text); }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--accent); color: #08080d;
    font-family: var(--font-sans); font-weight: 700; font-size: 0.9375rem;
    padding: 0.7rem 1.5rem; border-radius: 100px; text-decoration: none;
    transition: background var(--duration) var(--ease), transform var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }
  .btn-primary:hover {
    background: var(--accent-hover); color: #08080d;
    transform: translateY(-2px); box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: var(--text-muted); font-family: var(--font-sans);
    font-weight: 500; font-size: 0.9375rem; text-decoration: none;
    padding: 0.7rem 0; transition: color var(--duration) var(--ease);
  }
  .btn-ghost:hover { color: var(--text); }

  .hero-stats {
    display: flex; align-items: center; gap: 1.5rem;
  }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .stat-value { font-family: var(--font-sans); font-size: 1.25rem; font-weight: 700; color: var(--accent); line-height: 1; }
  .stat-label { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-divider { width: 1px; height: 32px; background: var(--border); }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .nebula-layer { animation: none !important; }
    .badge-dot    { animation: none !important; }
    .screen-lines { animation: none !important; }
    .hero-scene   { transform: translateY(-50%) !important; }
    .scene-head   { transform: none !important; }
  }
</style>
